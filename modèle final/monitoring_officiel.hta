<!doctype html>
<html>
<head>
  <meta http-equiv="x-ua-compatible" content="IE=11" />
  <meta charset="utf-8" />
  <title>Monitoring Officiel Launcher</title>
  <hta:application
    id="monitoringHta"
    applicationname="MonitoringOfficiel"
    border="thin"
    borderstyle="normal"
    caption="yes"
    contextmenu="no"
    icon=""
    maximizebutton="yes"
    minimizebutton="yes"
    navigable="yes"
    scroll="no"
    showintaskbar="yes"
    singleinstance="yes"
    sysmenu="yes"
    windowstate="normal"
  />
  <style>
    body { margin: 0; font-family: Segoe UI, Tahoma, sans-serif; background: #f4f7fb; }
    .top { padding: 10px 12px; background: linear-gradient(120deg, #0b3d91, #1478d4); color: white; }
    .bar { margin-top: 8px; display: flex; gap: 8px; flex-wrap: wrap; }
    button { border: 0; border-radius: 8px; padding: 8px 10px; font-weight: 600; cursor: pointer; }
    .btn-main { background: #0f172a; color: white; }
    .btn-secondary { background: #e6edf6; color: #1f2a37; }
    iframe { width: 100%; height: calc(100vh - 92px); border: 0; background: white; }
  </style>
  <script>
    function baseDir() {
      var p = decodeURIComponent(location.pathname || '');
      p = p.replace(/^\//, '').replace(/\//g, '\\');
      return p.substring(0, p.lastIndexOf('\\') + 1);
    }

    function runBat(name) {
      try {
        var shell = new ActiveXObject('WScript.Shell');
        shell.Run('cmd /c ""' + baseDir() + name + '""', 1, false);
      } catch (e) {
        alert('Impossible de lancer ' + name + ' : ' + e.message);
      }
    }

    function reloadPage() {
      document.getElementById('frame').src = 'monitoring_officiel.html?ts=' + new Date().getTime();
    }
  </script>
</head>
<body>
  <div class="top">
    <div><b>Monitoring Officiel (mode local executable)</b></div>
    <div class="bar">
      <button class="btn-main" onclick="runBat('run_modele_et_refresh.bat');">Lancer Modele + Refresh</button>
      <button class="btn-secondary" onclick="runBat('run_correction_manuelle.bat');">Lancer Correction Manuelle</button>
      <button class="btn-secondary" onclick="reloadPage();">Recharger la Page</button>
    </div>
  </div>
  <iframe id="frame" src="monitoring_officiel.html"></iframe>
</body>
</html>
