import cv2
from ultralytics import YOLO


def detect_and_blur_plate(input_path, output_path, model_path="license_plate_detector.pt"):
    """
    Détecte les plaques d'immatriculation et les floute.
    """

    # Charger le modèle
    model = YOLO(model_path)

    # Charger image
    image = cv2.imread(input_path)

    if image is None:
        raise ValueError("Erreur : image introuvable.")

    print("Image d'entrée récupérée.")

    # Copie pour modification
    blurred_image = image.copy()

    # Détection
    results = model(image)

    for result in results:
        for box in result.boxes:
            x1, y1, x2, y2 = map(int, box.xyxy[0])

            # Extraire région
            plate_region = blurred_image[y1:y2, x1:x2]

            # Appliquer flou
            blurred = cv2.GaussianBlur(plate_region, (99, 99), 30)

            blurred_image[y1:y2, x1:x2] = blurred

    # Sauvegarde
    cv2.imwrite(output_path, blurred_image)

    print("Image de sortie générée.")


# ------------------------
# Programme principal
# ------------------------
if __name__ == "__main__":
    detect_and_blur_plate(
        input_path="picture_of_the_parking.jpg",
        output_path="picture_of_the_parking_anonymized.jpg"
    )
